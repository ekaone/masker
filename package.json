{
  "name": "@ekaone/masker",
  "version": "0.0.4",
  "description": "Universal masking library, detects data type and applies appropriate masking automatically. Zero dependencies. TypeScript-native.",
  "keywords": [
    "mask",
    "masking",
    "redact",
    "pii",
    "privacy",
    "email",
    "credit-card",
    "ssn",
    "phone",
    "security",
    "data-protection",
    "typescript"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm clean && pnpm tsup",
    "dev": "tsx src/cli.ts",
    "watch": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run test && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/masker.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/masker/issues"
  },
  "homepage": "https://github.com/ekaone/masker#readme"
}
